<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Text?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="it.web.routex.fx.HomeFXController">

    <!-- =======================
         BACKGROUND
         ======================= -->
    <ImageView fitWidth="1400"
               fitHeight="900"
               preserveRatio="false">
        <image>
            <Image url="@images/light.jpg"/>
        </image>
    </ImageView>

    <!-- overlay scuro -->
    <Region style="-fx-background-color: rgba(0,0,0,0.4);" />

    <!-- =======================
         CONTENUTO PRINCIPALE
         ======================= -->
    <BorderPane prefWidth="1200" prefHeight="800">

        <!-- SINISTRA -->
        <left>
            <VBox spacing="15"
                  alignment="CENTER"
                  prefWidth="300"
                  style="-fx-background-color: rgba(0,0,0,0.6);">
                <padding>
                    <Insets top="30" bottom="30" left="30" right="30"/>
                </padding>

                <ImageView fitWidth="150" preserveRatio="true">
                    <image>
                        <Image url="@images/logo-no-background.png"/>
                    </image>
                </ImageView>

                <Label text="RouteX"
                       style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>

                <Text text="Navigating the Future,
One Stop at a Time"
                      textAlignment="CENTER"
                      style="-fx-fill: white; -fx-font-size: 16px;"/>
            </VBox>
        </left>

        <!-- DESTRA -->
        <center>
            <VBox spacing="20"
                  alignment="CENTER">

                <!-- PULSANTI LOGIN / REGISTER -->
                <HBox spacing="10"
                      alignment="TOP_RIGHT"
                      BorderPane.alignment="TOP_RIGHT">
                    <Button text="Register"
                            onAction="#onRegister"
                            styleClass="primary-button"/>
                    <Button text="Login"
                            onAction="#onLogin"
                            styleClass="primary-button"/>
                </HBox>

                <!-- WELCOME BOX -->
                <VBox spacing="20"
                      alignment="CENTER"
                      style="-fx-background-color: rgba(0,0,0,0.7); -fx-background-radius: 15;">
                    <padding>
                        <Insets top="30" bottom="30" left="40" right="40"/>
                    </padding>

                    <ImageView fitWidth="200" preserveRatio="true">
                        <image>
                            <Image url="@images/logo-no-background.png"/>
                        </image>
                    </ImageView>

                    <Label text="Welcome to RouteX!"
                           style="-fx-text-fill: white; -fx-font-size: 26px;"/>

                    <Button text="Start Exploring"
                            onAction="#onStartExploring"
                            style="-fx-font-size: 18px;
                                   -fx-background-color: #007bff;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 15;
                                   -fx-padding: 10 25;"/>
                </VBox>

            </VBox>
        </center>

    </BorderPane>

</StackPane>
